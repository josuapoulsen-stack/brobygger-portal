# ══════════════════════════════════════════════════════════════════════════════
# .env.example — SoS Brobygger Portal
#
# Kopiér til .env og udfyld med rigtige værdier.
# .env må ALDRIG committes til Git (se .gitignore).
#
# CI/CD: Sæt de samme variabler som GitHub Secrets (se AZURE_SETUP.md trin 7).
# ══════════════════════════════════════════════════════════════════════════════

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development                         # development | staging | production
LOG_LEVEL=info

# ── Database (Azure PostgreSQL Flexible Server) ───────────────────────────────
# Lokal dev:
DATABASE_URL=postgresql://bbadmin:password@localhost:5432/brobygger
# Azure (erstat med værdier fra Bicep-output):
# DATABASE_URL=postgresql://bbadmin:<password>@brobygger-dev-db.postgres.database.azure.com/brobygger?sslmode=require

# ── Azure Entra ID ─────────────────────────────────────────────────────────────
# Hentes fra Azure Portal → Entra ID → App registrations → Brobygger Portal
AZURE_CLIENT_ID=TODO_CLIENT_ID                  # Application (client) ID
AZURE_TENANT_ID=TODO_TENANT_ID                  # Directory (tenant) ID

# ── Azure SignalR ──────────────────────────────────────────────────────────────
# Hentes fra Azure Portal → SignalR → Connection strings
SIGNALR_CONNECTION_STRING=

# ── Web Push / VAPID ──────────────────────────────────────────────────────────
# Genereret 2026-04-29 — rotér ved sikkerhedshændelse
# Publicér VAPID_PUBLIC_KEY til frontend (VITE_VAPID_PUBLIC_KEY)
VAPID_PUBLIC_KEY=BOD0iVIOErOGHqocSw2UImskB_jmciBuQJQQ_uLl6dUnqDWtyByn5HPECFw_FW-fr3_8IByX1goo7_wQ0CeO004
VAPID_PRIVATE_KEY=8o_W1dsmZ5Am8fEigVVpVWj2rdkX7CALJh4QelOfwFM
VAPID_SUBJECT=mailto:admin@sosbrobygger.dk

# ── CORS ──────────────────────────────────────────────────────────────────────
# Kommasepareret liste (ingen mellemrum)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── JWT (kun dev — i prod bruges Entra ID RS256 JWKS) ─────────────────────────
JWT_SECRET=TODO_CHANGE_IN_PROD_min32chars_secret_key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ══════════════════════════════════════════════════════════════════════════════
# VITE-VARIABLER (frontend — præfiks VITE_ eksponeres i browser-bundle)
# Sættes i .env.local til lokal dev, eller som GitHub Secrets til CI/CD
# ══════════════════════════════════════════════════════════════════════════════

VITE_CLIENT_ID=TODO_CLIENT_ID
VITE_TENANT_ID=TODO_TENANT_ID
VITE_API_URL=http://localhost:8000
VITE_ENVIRONMENT=development
VITE_VAPID_PUBLIC_KEY=BOD0iVIOErOGHqocSw2UImskB_jmciBuQJQQ_uLl6dUnqDWtyByn5HPECFw_FW-fr3_8IByX1goo7_wQ0CeO004
