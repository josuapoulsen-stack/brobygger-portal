# Normalize line endings across platforms
* text=auto

# Force LF for source files
*.js   text eol=lf
*.jsx  text eol=lf
*.ts   text eol=lf
*.tsx  text eol=lf
*.py   text eol=lf
*.sql  text eol=lf
*.md   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.ini  text eol=lf
*.txt  text eol=lf
*.sh   text eol=lf
*.env  text eol=lf

# Binary — no line ending conversion
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.woff binary
*.woff2 binary
*.ttf  binary
*.otf  binary
*.pdf  binary
